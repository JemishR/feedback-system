* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

CHANGELOG.md export-ignore
README.md export-ignore
.github/workflows/browser-tests.yml export-ignore

# Auto-generated Wayfinder route/action files — not hand-written code
*.ts linguist-vendored

# Shadcn UI components — vendored UI library
resources/js/components/ui/*.tsx linguist-vendored

# Laravel Breeze scaffolded auth pages — boilerplate
resources/js/pages/auth/*.tsx linguist-vendored

# Scaffolded layouts and utility hooks
resources/js/layouts/*.tsx linguist-vendored
resources/js/layouts/app/*.tsx linguist-vendored
resources/js/layouts/auth/*.tsx linguist-vendored
resources/js/layouts/settings/*.tsx linguist-vendored
resources/js/hooks/*.tsx linguist-vendored

# Config/tooling files
*.js linguist-vendored
*.jsx linguist-vendored
*.css linguist-vendored
